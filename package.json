{
  "name": "kessan-tanshin-ai-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p worker/tsconfig.json && tsc --noEmit -p functions/tsconfig.json",
    "preview": "node scripts/dev-server.mjs --dist-only",
    "dev:vite": "vite --host 0.0.0.0",
    "build:vite": "vite build",
    "deploy:worker": "npx wrangler deploy --config worker/wrangler.toml",
    "test": "node scripts/test.mjs",
    "test:watch": "node scripts/test.mjs --watch"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.2",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.21.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.1",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
